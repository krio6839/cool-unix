		</cl-topbar>

		<view class="p-3">
			<!-- 顶部数据 -->
			<view class="flex flex-row justify-between mb-6">
				<view class="text-center">
					<cl-text :size="14" color="rgba(255,255,255,0.6)" :pt="{ className: 'mb-1' }">TSB</cl-text>
					<cl-text :size="24" color="white" :pt="{ className: 'font-bold' }">36</cl-text>
				</view>
