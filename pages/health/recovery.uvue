			:height="isMp() ? null : 50"
			background-color="transparent"
		>
			<view class="flex flex-row items-center justify-between w-full p-3">
				<cl-icon name="arrow-left-line" color="white" :size="20" @tap="goBack"></cl-icon>
				<cl-text :size="18" color="white">超量恢复黄金窗口</cl-text>
				<view class="w-5"></view>
			</view>
		</cl-topbar>

		<view class="p-3">
			<!-- 顶部数据 -->
			<view class="flex flex-row justify-between mb-6">
				<view class="text-center">
					<cl-text :size="14" color="rgba(255,255,255,0.6)" :pt="{ className: 'mb-1' }"
						>TSB</cl-text
					>
					<cl-text :size="24" color="white" :pt="{ className: 'font-bold' }">36</cl-text>
				</view>
				<view class="text-center">
					<cl-text :size="14" color="rgba(255,255,255,0.6)" :pt="{ className: 'mb-1' }"
						>短期负荷ATL</cl-text
					>
					<cl-text :size="24" color="white" :pt="{ className: 'font-bold' }">37</cl-text>
				</view>
				<view class="text-center">
					<cl-text :size="14" color="rgba(255,255,255,0.6)" :pt="{ className: 'mb-1' }"
						>长期负荷CTL</cl-text
					>
					<cl-text :size="24" color="white" :pt="{ className: 'font-bold' }">54</cl-text>
				</view>
			</view>

			<!-- 指标标记 -->
			<view class="flex flex-row mb-4">
				<view class="flex flex-row items-center mr-4">
					<view class="w-3 h-3 rounded-full bg-green-400 mr-2"></view>
					<cl-text :size="14" color="rgba(255,255,255,0.6)">ATL</cl-text>
				</view>
				<view class="flex flex-row items-center">
					<view class="w-3 h-3 rounded-full bg-orange-400 mr-2"></view>
					<cl-text :size="14" color="rgba(255,255,255,0.6)">CTL</cl-text>
				</view>
			</view>

			<!-- 趋势图表 -->
			<Chart :option="chartOption" :height="200" :showFooter="false"></Chart>

			<!-- 时间范围选择 -->
			<cl-tabs
				v-model="activeTimeRange"
