					:key="index"
					class="flex-1 text-center py-2 rounded-lg"
					:class="{ 'bg-primary-500 text-black': activeTimeRange === item.value, 'bg-surface-700 text-white': activeTimeRange !== item.value }"
					@tap="selectTimeRange(item.value)"
				>
					<cl-text :size="14">{{ item.label }}</cl-text>
				</view>
			</view>

			<!-- TSB训练疲劳度参考表 -->
			<view class="mb-6">
				<view class="flex flex-row justify-between items-center mb-3">
