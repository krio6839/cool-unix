				</view>
				<view class="text-center">
					<cl-text :size="14" color="rgba(255,255,255,0.6)" :pt="{ className: 'mb-1' }">长期负荷CTL</cl-text>
					<cl-text :size="24" color="white" :pt="{ className: 'font-bold' }">54</cl-text>
				</view>
			</view>

			<!-- 指标标记 -->
			<view class="flex flex-row mb-4">
				<view class="flex flex-row items-center mr-4">
					<view class="w-3 h-3 rounded-full bg-green-400 mr-2"></view>
					<cl-text :size="14" color="rgba(255,255,255,0.6)">ATL</cl-text>
