<template>
	<view class="health-card-grid">
		<view class="health-card" v-for="(item, index) in healthData" :key="index">
			<text class="title-text">{{ item.title }}</text>
			<view class="value-container">
				<text class="value-text">{{ item.value }}</text>
				<text class="unit-text">{{ item.unit }}</text>
			</view>
			<text class="change-text">{{ getChangeText(item.change) }}</text>
			<cl-svg class="health-card-icon" :src="item.icon"></cl-svg>
		</view>
	</view>
</template>

<script lang="ts" setup>
import { ref } from "vue";

const healthData = ref([
	{
		title: "心率",
		value: "73",
		unit: "bpm",
		change: 26,
		icon: "/static/icon/heart-rate.svg"
	},
	{
		title: "静息心率",
		value: "73",
		unit: "bpm",
		change: 27,
		icon: "/static/icon/heart-rate.svg"
	},
	{
		title: "血氧",
		value: "98",
		unit: "%",
		change: 0,
		icon: "/static/icon/blood-oxygen.svg"
	},
	{
		title: "心率变异性",
		value: "80",
		unit: "ms",
		change: 18,
		icon: "/static/icon/heart-rate-variability.svg"
	}
]);

const getChangeText = (change: number) => {
	if (change === 0) {
		return "";
	}
	return `较上次 ${change}%`;
};
</script>

