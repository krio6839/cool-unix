<template>
	<cl-page class="boom-coach-container" :back-top="false">
		<cl-topbar
			fixed
			:show-back="false"
			safe-area-top
			:height="isMp() ? null : 50"
			:pt="{
				className: '!z-50'
			}"
			background-color="transparent"
		>
			<view
				class="flex flex-row items-center justify-between p-3 flex-1 w-full"
				:class="{
					'pt-0': isMp()
				}"
			>
				<cl-svg src="/static/icon/coach/menu.svg" class="w-6 h-6"></cl-svg>
				<cl-text :size="18" class="ml-2">BOOM COACH </cl-text>

				<view class="flex flex-row">
					<cl-svg src="/static/icon/coach/start.svg" class="w-6 h-6 mr-4"></cl-svg>
					<cl-svg src="/static/icon/coach/chat-add.svg" class="w-6 h-6"></cl-svg>
				</view>
			</view>
		</cl-topbar>

		<!-- 对话区域 -->
		<scroll-view class="chat-area" scroll-y>
			<view v-if="messages.length === 0" class="greeting-section">
				<text class="greeting-title">BOOM COACH</text>
				<text class="greeting-message">昨天你睡的好吗？</text>
			</view>

			<view class="messages-container">
				<block v-for="(msg, index) in messages" :key="index">
					<!-- AI 消息 -->
					<view v-if="msg.role === 'ai'" class="message-row ai">
						<cl-svg src="/static/icon/coach/bot.svg" class="ai-avatar"></cl-svg>
						<view class="message-bubble ai">
							<text class="message-text">{{ msg.content }}</text>
							<view v-if="msg.isTyping" class="typing-indicator">
								<text class="dot"></text>
								<text class="dot"></text>
								<text class="dot"></text>
							</view>
						</view>
					</view>

					<!-- 用户消息 -->
					<view v-else class="message-row user">
						<view class="message-bubble user">
							<text class="message-text">{{ msg.content }}</text>
						</view>
					</view>
				</block>
			</view>
		</scroll-view>

		<!-- 输入区域 -->
		<view class="input-section">
			<cl-textarea
				v-model="inputValue"
				placeholder="有问题可以问我..."
				confirm-type="send"
				autofocus
				:showWordLimit="false"
				@confirm="sendMessage"
				:pt="{
					className: 'chat-input !bg-[#191915]',
					inner: {
						className: '!text-white'
					}
				}"
			></cl-textarea>
			<view class="absolute right-[60px] bottom-5">
				<cl-svg src="/static/icon/coach/voice.svg" class="w-6 h-6"></cl-svg>
			</view>
			<view class="absolute right-5 bottom-5" @tap="sendMessage">
				<cl-svg src="/static/icon/coach/send.svg" class="w-6 h-6"></cl-svg>
			</view>
		</view>

		<!-- 自定义底部导航栏 -->
		<custom-tabbar></custom-tabbar>
	</cl-page>
</template>

<script lang="ts" setup>
import { isApp, isMp, useRefs, t, dayUts } from "@/.cool";
import { ref, onMounted, nextTick } from "vue";
import { useUi } from "@/uni_modules/cool-ui";
import { config } from "@/config";
import CustomTabbar from "./components/tabbar.uvue";

const ui = useUi();
const refs = useRefs();

type MessageItem = {
	role: string;
	content: string;
	time: string;
	isTyping: boolean;
};

// 消息列表
const messages = ref<MessageItem[]>([
	{
		role: "user",
		content: "AI提示词：需要浅色的空间感背景",
		time: "",
		isTyping: false
	},
	{
		role: "ai",
		content:
			"1. 极简抽象风格\n\n浅色宇宙空间背景，柔和的淡蓝色与珍珠白渐变，漂浮着半透明的几何气泡，极简主义设计，低多边形风格，带有微妙的发光粒子，整体干净空旷，4K高清",
		time: "",
		isTyping: false
	},
	{
		role: "ai",
		content:
			"2. 自然光感风格\n\n朦胧的晨雾空间，浅杏色与淡紫渐变，阳光透过薄云形成丁达尔效应，空中悬浮透明水晶碎片，柔和的光斑效果，治愈系氛围，景深模糊",
		time: "",
		isTyping: false
	}
]);

// 输入框内容
const inputValue = ref<string>("");

// 模拟打字机效果
function simulateTyping(index: number, text: string) {
	let currentIndex = 0;
	const typingSpeed = 50; // 打字速度

	function typeNextChar() {
		if (currentIndex < text.length) {
			messages.value[index].content += text[currentIndex];
			currentIndex++;
			setTimeout(() => typeNextChar(), typingSpeed);
		} else {
			messages.value[index].isTyping = false;
		}
	}

	typeNextChar();
}

// 发送消息
const sendMessage = () => {
	console.log(inputValue.value);
	if (inputValue.value.trim().length == 0) return;

	// 添加用户消息
	messages.value.push({
		role: "user",
		content: inputValue.value,
		time: "",
		isTyping: false
	} as MessageItem);

	inputValue.value = "";

	// 模拟 AI 响应
	setTimeout(() => {
		// 添加 AI 消息
		const aiMsgIndex =
			messages.value.push({
				role: "ai",
				content: "",
				time: "",
				isTyping: true
			} as MessageItem) - 1;

		// 模拟打字机效果
		simulateTyping(
			aiMsgIndex,
			"这是一个模拟的 AI 响应。我正在模拟打字机效果，一个字一个字地输出内容。"
		);
	}, 500);
};

onMounted(() => {});
</script>

