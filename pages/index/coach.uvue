				.ai-avatar {
					width: 70rpx;
					height: 70rpx;
					margin-right: 20rpx;
					flex-shrink: 0;
				}

				.message-bubble {
					background-color: #191915;
					border-radius: 16rpx;
					border: 1rpx solid #25261f;
					padding: 24rpx;
					max-width: 80%;

					.message-text {
						font-size: 28rpx;
						line-height: 1.6;
						color: #fff;
					}
				}
			}

			&.user {
				display: flex;
				justify-content: flex-end;
				align-items: flex-end;

				.message-bubble {
					background: linear-gradient(to right, #ffcc00, #d2ff5c);
					border-radius: 50rpx 50rpx 0 50rpx;
					padding: 24rpx;
					max-width: 80%;

					.message-text {
						font-family:
							PingFang SC,
							PingFang SC;
