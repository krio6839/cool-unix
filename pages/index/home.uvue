				<view
					class="h-8 w-8 rounded-full border border-solid border-white opacity-60 flex flex-row items-center justify-center"
					:class="{
						'mr-24': isMp()
					}"
					@tap="goToCalendar"
				>
					<cl-icon name="calendar-line" color="white" :size="16"></cl-icon>
				</view>
			</view>
		</cl-topbar>

		<view class="p-3">
			<!-- 用户信息模块 -->
			<view class="relative">
				<UserInfo :user-info="userInfo"></UserInfo>

				<!-- 健康状态模块 -->
				<view class="absolute bottom-0 left-0 right-0">
					<HealthStatus :status="60" :sleep="70" :load="80"></HealthStatus>
				</view>
			</view>

			<!-- 储能数据模块 -->
			<view @tap="goToEnergyStorage">
				<EnergyRing class="mb-4" :percentage="energyPercentage"></EnergyRing>
			</view>

			<!-- BOOM GO -->
			<view
				class="boom-go mb-4 rounded-xl p-4 bg-gradient-to-r from-yellow-400 to-orange-500 text-white"
				@tap="goToBoomGo"
