<script lang="ts" setup>
import { isApp, isMp, useRefs, t, dayUts, router } from "@/.cool";
import { ref, onMounted } from "vue";
import { useUi } from "@/uni_modules/cool-ui";
import { config } from "@/config";
import CustomTabbar from "./components/tabbar.uvue";
import EnergyRing from "./components/energy-ring.uvue";
import HealthCard from "./components/health-card.uvue";
import HealthStatus from "./components/health-status.uvue";
import UserInfo from "./components/user-info.uvue";

const ui = useUi();
const refs = useRefs();
const energyPercentage = ref<number>(70);
const currentDate = ref<string>("");

// 格式化当前日期
function formatDate() {
	const date = dayUts();
	currentDate.value = `${date.format("MM月DD日")}`;
}

type UserInfoType = {
	name?: string;
	lastLoginTime?: string;
};

// 用户信息
const userInfo = ref<UserInfoType>({
	name: "张晓明",
	lastLoginTime: "2026.01.15"
});

const text1 = ref<string>(
	"前几天连续训练负荷较大，HRV较低但储能情况良好，预计明天HRV上升达到超量恢复黄金窗口。建议降低训练量，注意恢复调整"
);

onMounted(() => {
	formatDate();
});

function setSize() {
	refs.open("sizeSet");
}

function goToCalendar() {
	router.push({
		path: "/pages/set/calendar"
	});
}

function goToEnergyStorage() {
	router.push({
		path: "/pages/health/storage"
	});
}

function goToBoomGo() {
	router.push({
		path: "/pages/boom-go/index"
	});
}

function goToRecovery() {
	router.push({
		path: "/pages/health/recovery"
	});
}
</script>

<style lang="scss" scoped>
.user-info {
