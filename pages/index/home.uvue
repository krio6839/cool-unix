					</cl-text>
				</view>
				<cl-text :size="14" :pt="{ className: 'leading-relaxed' }">{{ text1 }} </cl-text>
			</view>

			<!-- 超量恢复 -->
			<view class="over-recovery mb-4 rounded-xl p-4 bg-black text-white" @tap="goToRecovery">
				<cl-text :size="16" :pt="{ className: 'font-bold mb-3' }">超量恢复</cl-text>
