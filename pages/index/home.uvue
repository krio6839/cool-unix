						:height="25"
						:show-loading="false"
					></cl-image>
				</view>

				<view class="mr-auto ml-2 flex flex-row items-center">
					<cl-text :size="22" :pt="{ className: 'mr-2' }"> 29℃ </cl-text>
					<cl-text
						:size="13"
						:pt="{
							className: 'opacity-60 mr-2'
						}"
					>
						海淀区
					</cl-text>
					<cl-text
						:size="13"
						:pt="{
							className: 'opacity-60'
						}"
					>
						{{ currentDate }}
					</cl-text>
				</view>

				<view
					class="h-8 w-8 rounded-full border border-solid border-white opacity-60 flex flex-row items-center justify-center mr-3"
