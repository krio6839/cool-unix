<script lang="ts" setup>
import { isApp, isMp, useRefs, t } from "@/.cool";
import { ref, onMounted } from "vue";
import { useUi } from "@/uni_modules/cool-ui";
import { config } from "@/config";
import LocaleSet from "@/components/locale-set.uvue";
import SizeSet from "@/components/size-set.uvue";
import CustomTabbar from "./components/tabbar.uvue";

const ui = useUi();
const refs = useRefs();
const energyChart = ref<any>(null);

// 用户信息
const userInfo = ref({
	name: "张三",
	avatar: "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=professional%20user%20avatar%20portrait%20simple%20style&image_size=square"
});

// 计算上次登录时间
const lastLoginTime = ref(() => {
	const now = new Date();
	const hours = now.getHours().toString().padStart(2, "0");
	const minutes = now.getMinutes().toString().padStart(2, "0");
	const seconds = now.getSeconds().toString().padStart(2, "0");
	const year = now.getFullYear();
	const month = (now.getMonth() + 1).toString().padStart(2, "0");
	const day = now.getDate().toString().padStart(2, "0");
	return `上次登录时间：${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
});

// 健康状态
const healthStatus = ref({
	heartRate: 72,
	spO2: 98,
	temperature: 36.5,
	sleep: 7.5
});

// 储能数据
const energyData = ref({
	daily: 2500,
	weekly: 17500,
	monthly: 75000
});

// 恢复建议
const suggestions = ref([
	{
		title: "补充水分",
		content: "建议每天饮用2000ml以上的水，保持身体水分平衡"
	},
	{
		title: "规律作息",
		content: "建议每天保持7-8小时的睡眠时间，有助于身体恢复"
	},
	{
		title: "适度运动",
		content: "建议每天进行30分钟的中等强度运动，增强身体免疫力"
	}
]);

// 储能数据图表配置
const energyChartOption = ref({
	title: {
		text: "储能趋势",
		left: "center",
		textStyle: {
			fontSize: 14
		}
	},
	xAxis: {
		type: "category",
		data: ["周一", "周二", "周三", "周四", "周五", "周六", "周日"]
	},
	yAxis: {
		type: "value",
		name: "kJ"
	},
	series: [
		{
			data: [2200, 2400, 2600, 2300, 2500, 2800, 2500],
			type: "line",
			areaStyle: {
				color: "rgba(76, 175, 80, 0.1)"
			},
			lineStyle: {
				color: "#4CAF50"
			},
			itemStyle: {
				color: "#4CAF50"
			}
		}
	]
});

function setLocale() {
	refs.open("localeSet");
}

function setSize() {
	refs.open("sizeSet");
}

function goToProfile() {
	// 导航到个人资料页面
	uni.navigateTo({
		url: "/pages/user/edit"
	});
}

onMounted(() => {
	// 初始化图表
	if (energyChart.value) {
		// 图表已在模板中通过 ref 引用，会自动初始化
	}
});
</script>

